rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is an admin by looking at their user document or fallback email
    function isAdmin() {
      return request.auth != null && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email == 'nexa2114@gmail.com'
      );
    }

    // Check if the document belongs to the authenticated user
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Anyone authenticated can create their own profile during registration
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      // Clients can read their own orders. Admins read everything.
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // --- Messages Collection (Chat) ---
    match /messages/{messageId} {
      // Clients read messages linked to their ID. Admins read everything.
      allow read: if isAdmin() || (request.auth != null && resource.data.clientUserId == request.auth.uid);
      
      // Admins and authenticated clients can send messages
      allow create: if request.auth != null;
      
      // Admins update to mark as read. Clients could update to mark admin messages as read in the future.
      allow update: if request.auth != null; 
      
      // Only admins can delete messages
      allow delete: if isAdmin();
    }

    // --- Activity Collection (Admin Monitor / System Logs) ---
    match /activity/{activityId} {
      allow read, update, delete: if isAdmin();
      // Clients create activity upon payment attempts or completions
      allow create: if request.auth != null;
    }

    // --- Chat Meta Collection (Presence/Typing) ---
    match /chat_meta/{orderId} {
      // Both clients and admins need to read/write presence info
      allow read, write: if request.auth != null;
    }

    // --- System Collection (Global Meta) ---
    match /system/{docId} {
      // Anyone can read global presence
      allow read: if request.auth != null;
      // Only admins can update the adminPresence doc
      allow write: if isAdmin();
    }

    // Default deny all other collections to prevent unauthorized access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
